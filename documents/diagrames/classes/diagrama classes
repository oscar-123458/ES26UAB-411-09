@startuml

class UsuariNoRegistrat {
  +consultarMenus()
  + crearCompte()
}

class UsuariRegistrat {
  - correu: String
  - nomUsuari: String
  - contrasenya: String
  - adreca: String
  + iniciarSessio()
  + modificarPerfil()
  + donarDeBaixa()
  + gestionarRols()
}

class Client {
  - puntsAcumulats: int
  + ferComanda()
  + reservarComanda()
  + proposarPlat()
  + valorarComanda()
  + pagarComanda()
}

class Cuiner {
  - compteBancari: String
  - horarisDisponibilitat: String
  + gestionarCataleg()
  + modificarDisponibilitat()
  + acceptarComanda()
  + rebutjarComanda()
  + acceptarPlatPersonalitzat()
  + rebrePagament()
}

class Repartidor {
  - compteBancari: String
  - ubicacioActual: Coordenades
  + compartirUbicacio()
  + actualitzarEstatEnviament()
  + rebrePagament()
}

UsuariNoRegistrat <|-- UsuariRegistrat

UsuariRegistrat <|-- Client
UsuariRegistrat <|-- Cuiner
UsuariRegistrat <|-- Repartidor

class Menu {
  - nomMenu: String
  + mostrarPlats()
}

class Plat {
  - nomPlat: String
  - descripcio: String
  - preu: float
  - disponible: boolean
}

class Plat_personalitzat {
  - descripcioProposta: String
  - estatProposta: String
}

class Cataleg {
  + obtenirPlatsDisponibles()
  + actualitzarCataleg()
}

class Comanda {
  - idComanda: int
  - estat: String
  - metodeRecollida: String
  - esReserva: boolean
  - data: Date
  + tancarComanda()
}

class Pagament {
  - importTotal: float
  - metode: String
  - estatPagament: String
  + processarPagament()
}

class Enviament {
  - estatEnviament: String
  - adrecaLliurament: String
}

class Valoració {
  - puntuacio: int
  - comentari: String
}

class Xat {
  - idXat: int
  + obrirXat()
}

class Alergens {
  - nomAlergen: String
}

class Ingredients {
  - nomIngredient: String
  - esOpcional: boolean
}

class Historial {
  + obtenirComandesPrèvies()
}

class Missatge {
  - contingut: String
  - dataEnviament: Date
}

class Subscripcio {
  - tipus: String
  - actiu: boolean
}

UsuariNoRegistrat "0..*" -- "1..*" Menu : consulta >

Cataleg "1" -- "1..*" Plat : conté >
Menu "1" -- "1..*" Cataleg : té >
Cuiner "1" -- "1" Cataleg : gestiona >

Client "1" -- "0..*" Comanda : realitza >
Comanda "1..*" -- "1..*" Plat : inclou >
Comanda "0..*" -- "1" Cuiner : preparada per >
Client "1" -- "0..1" Subscripcio : té >
Client "1" -- "0..*" Alergens : té >

Comanda "1" -- "1" Pagament : genera >
Comanda "1" -- "0..1" Enviament : té >
Enviament "0..*" -- "1" Repartidor : assignat a >

Client "1" -- "0..*" Valoració : realitza >
Valoració "1" -- "1" Comanda : puntua >
Xat "1" -- "0..*" Missatge : conté >
Client "1" -- "0..1" Xat : inicia >
Cuiner "1" -- "0..1" Xat : respon >
Plat "1" -- "0..*" Alergens : conté >
Plat "1" -- "1..*" Ingredients : conté >
Plat "1" -- "0..*" Plat_personalitzat : pot ser >
Client "1" -- "1" Historial : té >
Historial "1" -- "0..*" Comanda : conté >

@enduml
