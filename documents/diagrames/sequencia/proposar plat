@startuml

actor Client
actor Cuiner

boundary "Interfície Proposta de Plat" as IPP
control "Controlador Propostes" as CP
entity "SuggerimentPlat" as SP
entity "Xat" as X
entity "Missatge" as M

Client -> IPP : Descriure plat suggerit
IPP -> CP : enviarSuggeriment()

CP -> SP : guardarSuggeriment()
SP --> CP : suggerimentGuardat

CP -> SP : publicarSuggeriment()
SP --> CP : suggerimentDisponible

CP --> Cuiner : mostrarSuggeriment()

alt Acceptar proposta

    Cuiner -> CP : acceptarProposta()
    CP -> SP : marcarAcceptada()
    SP --> CP : propostaActualitzada
    CP --> Client : notificarAcceptació()

else Rebutjar proposta

    Cuiner -> CP : rebutjarProposta()
    CP -> SP : marcarRebutjada()
    SP --> CP : propostaActualitzada
    CP --> Client : notificarRebuig()

else Discutir proposta mitjançant xat

    Cuiner -> CP : sol·licitarXat()
    CP -> X : crearXat()
    X --> CP : xatCreat

    CP --> Client : notificarSol·licitud()

    loop Intercanvi de missatges

        Client -> CP : enviarMissatge()
        CP -> M : crearMissatge()
        M --> CP : missatgeCreat
        CP -> X : afegirMissatge()
        X --> CP : missatgeAfegit
        CP --> Cuiner : mostrarMissatge()

        Cuiner -> CP : respondreMissatge()
        CP -> M : crearMissatge()
        M --> CP : missatgeCreat
        CP -> X : afegirMissatge()
        X --> CP : missatgeAfegit
        CP --> Client : mostrarResposta()

    end

end

@enduml