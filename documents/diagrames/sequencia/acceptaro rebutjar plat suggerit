@startuml

actor Cuiner
actor Client

boundary "Interfície Plats Personalitzats" as IPP
control "Controlador Plats Personalitzats" as CPP
entity "plat_personalitzat" as SP
entity "Xat" as X

Cuiner -> IPP : Accedir a plats personalitzats
IPP -> CPP : sol·licitarSuggeriments()

CPP -> SP : obtenirSuggeriments()
SP --> CPP : llistaSuggeriments

CPP --> IPP : mostrarSuggeriments()

Cuiner -> IPP : Acceptar o rebutjar plat

alt Acceptar

    IPP -> CPP : acceptarPlat()

    CPP -> SP : marcarAcceptat()
    SP --> CPP : suggerimentActualitzat

    CPP -> X : crearXatPrivat()
    X --> CPP : xatCreat

    CPP --> Client : notificarAcceptació()

else Rebutjar

    IPP -> CPP : rebutjarPlat()

    CPP -> SP : marcarRebutjat()
    SP --> CPP : suggerimentActualitzat

    CPP --> Client : notificarRebuig()

end

@enduml