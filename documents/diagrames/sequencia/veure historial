@startuml

actor Client

boundary "Interfície Historial" as IH
control "Controlador Historial" as CH
entity "PerfilClient" as PC
entity "Comanda" as C

Client -> IH : Entrar a l'historial
IH -> CH : sol·licitarHistorial()

CH -> PC : obtenirComandes()
PC --> CH : llistaComandes

CH --> IH : mostrarComandes()

Client -> IH : Seleccionar plat o menú
IH -> CH : tornarAEncarrregar(item)

CH -> C : comprovarDisponibilitat(item)

alt Disponible
    C --> CH : disponible
    CH -> C : crearNovaComanda(item)
    C --> CH : comandaCreada
    CH --> IH : confirmarComanda()
else No disponible
    C --> CH : noDisponible
    CH --> IH : mostrarError()
end

@enduml