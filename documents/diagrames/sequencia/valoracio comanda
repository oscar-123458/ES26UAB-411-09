@startuml

actor Client

boundary "Interfície Valoració" as IVC
control "Controlador Valoració" as CV
entity "Valoració" as V

Client -> IVC : Seleccionar la comanda rebuda
IVC -> CV : sol·licitarFormulari()

CV --> IVC : mostrarFormulari()

Client -> IVC : Emplenar els camps
IVC -> CV : enviarValoracio()

alt Informació completa i vàlida
    CV -> V : guardarValoracio()
    V --> CV : valoracioGuardada

    CV -> V : processarValoracio()
    V --> CV : valoracioProcessada

    CV --> IVC : confirmarValoracio()
else Informació incompleta o no vàlida
    CV --> IVC : mostrarError()
    IVC --> Client : Informar de camps obligatoris\no dades no vàlides
end

@enduml