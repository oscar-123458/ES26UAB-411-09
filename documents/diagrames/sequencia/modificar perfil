@startuml

actor "Usuari registrat" as Usuari

boundary "Interfície Perfil" as IMP
control "Controlador Perfil" as CP
entity "PerfilUsuari" as PU

Usuari -> IMP : Accedir a modificar perfil

IMP -> CP : sol·licitarConfiguracio()

CP -> PU : obtenirDadesPerfil()
PU --> CP : dadesPerfil

CP --> IMP : mostrarConfiguracioActual()

Usuari -> IMP : Modificar paràmetres
IMP -> CP : enviarCanvis()

alt Canvi de rol o eliminació del compte
    CP --> IMP : sol·licitarSegonaConfirmacio()
    IMP --> Usuari : Mostrar advertència
    Usuari -> IMP : Confirmar operació
    IMP -> CP : confirmacioRebuda()
end

CP -> PU : actualitzarPerfil()
PU --> CP : canvisAplicats

CP --> IMP : confirmarModificacio()

@enduml